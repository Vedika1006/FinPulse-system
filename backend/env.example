# Copy to "backend/.env" and adjust.

# JWT (set a long random string in production)
SECRET_KEY=replace-with-long-random-string
ALGORITHM=HS256

# Database (optional): if unset, backend uses SQLite at backend/expense_ai.db
# For Postgres, set DATABASE_URL (do not set USE_SQLITE):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/expense_ai_db

# Force SQLite even when DATABASE_URL is set:
# USE_SQLITE=1

# Return real exception messages in JSON (dev only):
# DEBUG_API_ERRORS=1

# Groq (required for AI chat, receipt scanning, and merchant categorization fallback)
GROQ_API_KEY=

# Optional: override the default model IDs (Groq periodically deprecates
# models — update these instead of editing code when that happens):
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.1-8b-instant
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional Gemini (pip install -r requirements-ai.txt)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
